---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface FaqItem {
  q: string;
  a: string;
}

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  faq?: FaqItem[];
}

const {
  title,
  description = 'Calm, practical personal finance for beginners.',
  ogImage,
  faq,
} = Astro.props;

const ogImageUrl = new URL(ogImage ?? '/images/og/default.png', Astro.site).href;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const faqJsonLd = faq && faq.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faq.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    }
  : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta name='impact-site-verification' value='64101e86-a164-443e-ba6b-04ae48059a87' />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:site_name" content="Beginner Finance Hub" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    {faqJsonLd && <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet" />
    <title>{title} | Beginner Finance Hub</title>
  </head>
  <body>
    <header class="site-header">
      <Nav />
    </header>
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
