---
import BaseLayout from './BaseLayout.astro';
import AuthorByline from '../components/AuthorByline.astro';
import RelatedArticles from '../components/RelatedArticles.astro';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface RelatedArticle {
  title: string;
  url: string;
}

interface FaqItem {
  q: string;
  a: string;
}

interface Props {
  title: string;
  description?: string;
  pubDate?: Date;
  updatedDate?: Date;
  readTime?: number;
  headings?: Heading[];
  relatedArticles?: RelatedArticle[];
  image?: string;
  imageAlt?: string;
  ogImage?: string;
  faq?: FaqItem[];
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  readTime,
  headings = [],
  relatedArticles = [],
  image,
  imageAlt,
  ogImage,
  faq,
} = Astro.props;

// Only render TOC when there are 2+ H2 headings (AC-5)
const h2Headings = headings.filter(h => h.depth === 2);
const showToc = h2Headings.length >= 2;
---

<BaseLayout title={title} description={description} ogImage={ogImage ?? image} faq={faq} wideLayout={showToc}>
  <article class="article-layout">

    {showToc && (
      <aside class="article-toc-rail">
        <nav class="article-toc" aria-label="Table of contents">
          <p class="article-toc-heading">Contents</p>
          <ol>
            {h2Headings.map(h => (
              <li><a href={`#${h.slug}`}>{h.text}</a></li>
            ))}
          </ol>
        </nav>
      </aside>
    )}

    <div class="article-main">
      <header>
        {image && <img class="article-hero" src={image} alt={imageAlt ?? ''} width="1200" height="630" loading="eager" />}
        <h1>{title}</h1>
        <AuthorByline pubDate={pubDate} updatedDate={updatedDate} readTime={readTime} />
      </header>

      <div class="article-body">
        <slot />
      </div>

      <RelatedArticles articles={relatedArticles} />

      <div class="email-strip">
        <h2>New guides, delivered free</h2>
        <p>Plain-English personal finance, one guide at a time. No spam, no advice framing &mdash; just education.</p>
        <div class="email-strip-form" aria-hidden="true">
          <input
            class="email-strip-input"
            type="email"
            placeholder="your@email.com"
            disabled
            aria-label="Email address (signup not yet active)"
          />
          <button class="email-strip-btn" type="button" disabled>Send me guides</button>
        </div>
        <span class="email-strip-note">Coming soon &mdash; email capture activates after setup is complete.</span>
      </div>
    </div>

  </article>
</BaseLayout>
