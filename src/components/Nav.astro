---
const navLinks = [
  { href: '/start-here', label: 'Start Here' },
  { href: '/hub', label: 'Finance Hub' },
  { href: '/articles', label: 'Articles' },
];
---

<div class="site-header-inner">
  <a href="/" class="site-name" aria-label="Beginner Finance Hub home">
    <img
      src="/brand/wordmark.svg"
      alt="Beginner Finance Hub"
      class="site-wordmark"
      width="220"
      height="28"
    />
  </a>
  <nav class="site-nav">
    <ul>
      {navLinks.map(link => (
        <li><a href={link.href}>{link.label}</a></li>
      ))}
    </ul>
  </nav>
</div>
